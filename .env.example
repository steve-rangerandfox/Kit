# ─── Plaud (https://plaud.ai) — meeting transcription ────────
# Webhook signing secret (required for any webhook traffic to be accepted)
PLAUD_WEBHOOK_SECRET=
# API key for the Plaud Transcription API. Required only when PLAUD_INGEST_ENABLED=true.
PLAUD_API_KEY=
# Master switch for the transcript-fetch + RAG ingest path. Leave 'false' until
# you have a working Plaud dev app and a verified webhook test run.
PLAUD_INGEST_ENABLED=false
# Replay-protection window for plaud-timestamp header, in seconds.
PLAUD_TIMESTAMP_SKEW_SECONDS=300
# Optional Slack channel id for transcription.failed notices.
PLAUD_ERROR_CHANNEL_ID=
# Default workspace id to attribute Plaud-derived sessions to (required when
# PLAUD_INGEST_ENABLED=true). Set to a real Supabase workspaces.id value.
KIT_DEFAULT_WORKSPACE_ID=

# ─── Google Calendar — pre-meeting briefings ─────────────────
# Master switch for the briefing cron. Leave 'false' until creds + calendars
# are set up and you've verified a test event flows through.
GOOGLE_CALENDAR_INGEST_ENABLED=false
# Service account JSON (raw, or base64-encoded). Required when INGEST_ENABLED=true.
GOOGLE_SERVICE_ACCOUNT_JSON=
# Comma-separated calendar IDs the service account has been shared into.
GOOGLE_CALENDAR_IDS=
# How far in advance to send briefings (minutes; default 30).
BRIEFING_LEAD_TIME_MINUTES=30
# Classifier confidence below which an event is skipped (0..1; default 0.5).
BRIEFING_MATCH_THRESHOLD=0.5
# Also post briefings to the project channel? PRIVACY: off by default —
# the channel exposes the prep to everyone in it, not just people on the call.
BRIEFING_POST_CHANNEL=false

# ─── Freelancer NDA / paperwork ───────────────────────────────
# Master switch. Leave 'false' until the items below are configured and the
# NDA template + Gmail delegation are verified.
FREELANCER_PAPERWORK_ENABLED=false
# The Workspace mailbox the NDA is sent *as* (Gmail impersonates this user).
# Requires domain-wide delegation: authorize the GOOGLE_SERVICE_ACCOUNT_JSON
# service account's client id for these scopes in Google Workspace Admin:
#   https://www.googleapis.com/auth/gmail.send  (send the NDA email)
#   https://www.googleapis.com/auth/drive       (convert the Company NDA .docx → PDF)
# The drive scope is only needed for the Company NDA (docx→PDF). The Individual
# NDA is a static PDF and needs only gmail.send.
ONBOARDING_FROM_EMAIL=
# Comma-separated cc list for the NDA email (studio copy). Default: Jared.
ONBOARDING_NDA_CC=jared@rangerandfox.tv
# (Reuses GOOGLE_SERVICE_ACCOUNT_JSON above — no separate credential needed.)

# ─── Delivery pipeline ────────────────────────────────────────
# Slack channel where Dropbox-detected files get posted for "pick a profile".
# Leave blank to disable the auto-scan notification (still works manually
# via `/kit deliver <path>`).
DELIVERY_NOTIFY_CHANNEL_ID=
# Comma-separated file extensions the Dropbox→Frame.io watcher should NOT
# mirror (e.g. audio sidecars dropped next to the video). Defaults to aac,m4v.
DELIVERY_DENY_EXTENSIONS=aac,m4v

# ─── Studio knowledge (RAG embeddings) ───────────────────────
# OpenAI API key for text-embedding-3-small. Required for the studio_knowledge
# agent to function. The same key is used by the project-summary embedder and
# (future) the notes capture path.
OPENAI_API_KEY=

# ─── Studio knowledge auto-summarization ─────────────────────
# Nightly cron regenerates per-project narrative summaries via Claude Haiku.
# Leave 'false' until you've verified the P1 backfill produced clean
# project_summary docs and don't want them auto-overwritten.
STUDIO_KNOWLEDGE_AUTO_SUMMARIZE_ENABLED=false

# ─── Slack (required on Vercel too — briefings post from Inngest) ──
SLACK_BOT_TOKEN=

# ─── Supabase (required) ──────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Anthropic (classifier, briefing prep notes, bizdev bios) ─
ANTHROPIC_API_KEY=

# ─── Inngest (cron scheduling — REQUIRED in production) ───────
# Without these, /api/inngest can't authenticate to Inngest Cloud and every
# cron (briefings, delivery scans, Plaud, brain) silently never fires.
INNGEST_SIGNING_KEY=
INNGEST_EVENT_KEY=

# ─── Dropbox + Frame.io (delivery crons run on Vercel) ────────
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REFRESH_TOKEN=
FRAMEIO_ADOBE_CLIENT_ID=
FRAMEIO_ADOBE_CLIENT_SECRET=
FRAMEIO_ADOBE_REFRESH_TOKEN=
FRAMEIO_ACCOUNT_ID=
FRAMEIO_WORKSPACE_ID=
