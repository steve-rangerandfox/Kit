{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "TextBlock",
      "text": "🚀 New Project Provisioner",
      "weight": "Bolder",
      "size": "ExtraLarge",
      "color": "Accent"
    },
    {
      "type": "TextBlock",
      "text": "Fill in the details below to automatically provision all project infrastructure.",
      "wrap": true,
      "spacing": "Small",
      "isSubtle": true
    },
    {
      "type": "Container",
      "style": "emphasis",
      "spacing": "Medium",
      "items": [
        {
          "type": "TextBlock",
          "text": "PROJECT DETAILS",
          "weight": "Bolder",
          "size": "Small",
          "spacing": "None"
        }
      ]
    },
    {
      "type": "Input.Text",
      "id": "projectName",
      "label": "Project Name *",
      "placeholder": "e.g. Q3 Brand Campaign",
      "isRequired": true,
      "errorMessage": "Project name is required."
    },
    {
      "type": "Input.Text",
      "id": "clientName",
      "label": "Client Name *",
      "placeholder": "e.g. Acme Corporation",
      "isRequired": true,
      "errorMessage": "Client name is required."
    },
    {
      "type": "Input.ChoiceSet",
      "id": "projectType",
      "label": "Project Type *",
      "isRequired": true,
      "errorMessage": "Please select a project type.",
      "style": "compact",
      "choices": [
        { "title": "Brand Video", "value": "Brand Video" },
        { "title": "Motion Graphics", "value": "Motion Graphics" },
        { "title": "Social Campaign", "value": "Social Campaign" },
        { "title": "Explainer", "value": "Explainer" },
        { "title": "Broadcast", "value": "Broadcast" },
        { "title": "Other", "value": "Other" }
      ]
    },
    {
      "type": "Input.Text",
      "id": "projectManager",
      "label": "Project Manager *",
      "placeholder": "Email address",
      "isRequired": true,
      "errorMessage": "Project manager is required."
    },
    {
      "type": "Input.Text",
      "id": "teamMembers",
      "label": "Team Members",
      "placeholder": "Comma-separated emails: jane@studio.com, john@studio.com",
      "isMultiline": false
    },
    {
      "type": "ColumnSet",
      "spacing": "Medium",
      "columns": [
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "Input.Date",
              "id": "startDate",
              "label": "Estimated Start Date"
            }
          ]
        },
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "Input.Date",
              "id": "deadline",
              "label": "Estimated Deadline"
            }
          ]
        }
      ]
    },
    {
      "type": "Input.Text",
      "id": "description",
      "label": "Brief Description",
      "placeholder": "Optional: key deliverables, creative direction, notes...",
      "isMultiline": true,
      "maxLength": 1000
    },
    {
      "type": "Container",
      "style": "emphasis",
      "spacing": "Large",
      "items": [
        {
          "type": "TextBlock",
          "text": "SERVICES TO PROVISION",
          "weight": "Bolder",
          "size": "Small",
          "spacing": "None"
        },
        {
          "type": "TextBlock",
          "text": "Uncheck any platforms you don't need for this project.",
          "wrap": true,
          "isSubtle": true,
          "size": "Small",
          "spacing": "Small"
        }
      ]
    },
    {
      "type": "ColumnSet",
      "spacing": "Small",
      "columns": [
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "Input.Toggle",
              "id": "svc_dropbox",
              "title": "📦  Dropbox",
              "value": "true",
              "valueOn": "true",
              "valueOff": "false"
            },
            {
              "type": "Input.Toggle",
              "id": "svc_frameio",
              "title": "🎬  Frame.io",
              "value": "true",
              "valueOn": "true",
              "valueOff": "false"
            },
            {
              "type": "Input.Toggle",
              "id": "svc_onedrive",
              "title": "💾  OneDrive",
              "value": "true",
              "valueOn": "true",
              "valueOff": "false"
            },
            {
              "type": "Input.Toggle",
              "id": "svc_clockify",
              "title": "⏱  Clockify",
              "value": "true",
              "valueOn": "true",
              "valueOff": "false"
            }
          ]
        },
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "Input.Toggle",
              "id": "svc_canva",
              "title": "🎨  Canva",
              "value": "true",
              "valueOn": "true",
              "valueOff": "false"
            },
            {
              "type": "Input.Toggle",
              "id": "svc_figma",
              "title": "📐  FigJam",
              "value": "true",
              "valueOn": "true",
              "valueOff": "false"
            },
            {
              "type": "Input.Toggle",
              "id": "svc_notion",
              "title": "📓  Notion",
              "value": "true",
              "valueOn": "true",
              "valueOff": "false"
            },
            {
              "type": "Input.Toggle",
              "id": "svc_teams",
              "title": "💬  Teams Chat",
              "value": "true",
              "valueOn": "true",
              "valueOff": "false"
            }
          ]
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "🚀 Provision Project",
      "style": "positive",
      "data": {
        "action": "provisionProject"
      }
    }
  ]
}
