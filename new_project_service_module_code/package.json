{
  "name": "new-project-provisioner",
  "version": "1.0.0",
  "description": "Microsoft Teams bot that provisions project infrastructure across 8 platforms",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "start": "func start",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:integration": "ts-node scripts/test-run.ts",
    "lint": "eslint src/**/*.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@azure/functions": "^4.0.0",
    "@microsoft/microsoft-graph-client": "^3.0.0",
    "axios": "^1.6.0",
    "botbuilder": "^4.21.0",
    "botframework-connector": "^4.21.0",
    "dotenv": "^16.3.0",
    "identity-client": "^1.0.0",
    "@azure/identity": "^4.0.0",
    "isomorphic-fetch": "^3.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/index.ts"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  }
}
