# ─── Slack ─────────────────────────────────────────────────
# OAuth tokens for the Bolt app's Slack workspace.
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# ─── Anthropic ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Server ────────────────────────────────────────────────
PORT=3000

# ─── Frame.io v4 (Adobe IMS) ───────────────────────────────
# Frame.io v4 authenticates via Adobe IMS OAuth. You need a refresh token
# from an Adobe Developer Console project with the Frame.io API enabled.
ADOBE_CLIENT_ID=
ADOBE_CLIENT_SECRET=
ADOBE_REFRESH_TOKEN=

# Account + workspace IDs replace the legacy v2 FRAMEIO_TEAM_ID concept.
FRAMEIO_ACCOUNT_ID=
FRAMEIO_WORKSPACE_ID=
