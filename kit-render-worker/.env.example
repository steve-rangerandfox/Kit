# Supabase connection (same Kit project)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Worker identity (auto-detected from OS hostname if WORKER_HOSTNAME is unset)
WORKER_HOSTNAME=
WORKER_DISPLAY_NAME=
WORKER_ROLE=fallback           # "primary" or "fallback"
WORKER_PRIORITY=10             # 1 = primary, higher = lower priority

# Dropbox sync folder on this machine
DROPBOX_SYNC_PATH=D:\Dropbox

# FFmpeg
FFMPEG_PATH=ffmpeg             # full path or just "ffmpeg" if on PATH

# After Effects render farm (optional — leave AERENDER_PATH blank on machines
# without After Effects; they'll still run transcode + stitch jobs).
# When AERENDER_PATH points at an existing aerender.exe this worker becomes
# AE-capable and will claim aerender frame-chunk jobs.
AERENDER_PATH=                 # e.g. C:\Program Files\Adobe\Adobe After Effects 2025\Support Files\aerender.exe
AE_VERSION=                    # optional label, e.g. "2025" (reported in heartbeat)
# AE_CAPABLE=                  # optional override ("true"/"false"); auto-detected from AERENDER_PATH otherwise

# Thresholds
CPU_THRESHOLD=50               # fallback workers won't claim if CPU > this %
MIN_DISK_FREE_GB=10            # won't claim if local disk < this

# Polling intervals (milliseconds)
HEARTBEAT_INTERVAL_MS=10000
POLL_INTERVAL_MS=5000          # primary; fallback workers poll less often automatically
FALLBACK_DELAY_SECONDS=30      # fallback worker won't claim a job younger than this
