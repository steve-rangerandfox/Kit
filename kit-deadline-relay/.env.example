# ─── Supabase (same Kit project) ──────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Deadline ─────────────────────────────────────────────────
# deadlinecommand.exe. Auto-derived from the DEADLINE_PATH env var Deadline
# sets, or point at it directly.
DEADLINECOMMAND_PATH=C:\Program Files\Thinkbox\Deadline10\bin\deadlinecommand.exe

# ISOLATION: this integration must stay additive and never touch the production
# C4D setup. Submit to a DEDICATED AE group + the KitAfterEffects custom plugin
# overlay so AE jobs never land on C4D nodes and no stock config is modified.
DEADLINE_PLUGIN=KitAfterEffects
DEADLINE_POOL=none
DEADLINE_GROUP=kit_ae
DEADLINE_PRIORITY=50

# AE version for the plugin's "Version" param. AE 2026 = internal v26; needs a
# RenderExecutable26_0 entry in the KitAfterEffects overlay (see README).
AE_VERSION=26.0

# Frames per Deadline task for image sequences (how finely work splits across
# the farm).
DEADLINE_CHUNK_SIZE=10

# ─── Path normalization (SAN) ─────────────────────────────────
# Projects live on the production SAN (\\thewire\production\...). These rules
# rewrite drive letters to UNC ("from=>to;..."; longest match wins) so headless
# Workers resolve paths. UNC input passes through unchanged.
DEADLINE_PATH_MAP=Z:=>\\thewire\production

# ─── After Effects on this relay box (AE 2026 required) ───────
# AfterFX.exe prepares each project: captures the queued items' output modules,
# overrides them to PNG sequences for frame-splitting, queues WAV audio passes,
# saves the __kitfarm.aep farm copy.
AFTERFX_PATH=C:\Program Files\Adobe\Adobe After Effects 2026\Support Files\AfterFX.exe
# aerender for the local audio pass; derived next to AfterFX.exe if blank.
AERENDER_PATH=

# ─── Assemble step (frames + audio → deliverable) ─────────────
# FFmpeg on this relay box (winget install Gyan.FFmpeg, or a full path).
# Compiles the finished PNG sequence into the artist's original output format
# (ProRes 422, H.264, ...) at the comp's frame rate, muxing the audio pass.
FFMPEG_PATH=ffmpeg
# Keep the PNG frames after a successful assemble (default: delete them).
AE_KEEP_FRAMES=false

# ─── Relay ────────────────────────────────────────────────────
RELAY_HOSTNAME=                 # defaults to OS hostname
POLL_INTERVAL_MS=10000          # how often to claim new renders + poll Deadline status
